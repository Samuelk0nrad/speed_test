*** Presentation ***

template = /etc/smokeping/basepage.html

+ charts

menu = Charts
title = Latency charts

++ stddev
sorter = StdDev(entries=>4)
title = Top Standard Deviation
menu = Std Deviation
format = Standard Deviation %f

++ max
sorter = Max(entries=>4)
title = Top Max Roundtrip Time
menu = Max
format = Max Roundtrip Time %f seconds

++ loss
sorter = Loss(entries=>4)
title = Top Packet Loss
menu = Loss
format = Packets Lost %f

+ overview

width = 600
height = 50
range = 10h

+ detail

width = 600
height = 200
unison_tolerance = 2

"Last 10 Hours"    10h
"Last 24 Hours"    24h
"Last 7 Days"       7d
"Last 30 Days"     30d
"Last Year"       365d

